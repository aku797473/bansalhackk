# ===================================
# SMART KISAN — Environment Variables
# Copy this file to .env and fill in
# ===================================

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-kisan
# Or Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/smart-kisan

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKER=localhost:9092

# Firebase (for OTP Auth)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@project.iam.gserviceaccount.com

# Google APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_key               # free at ai.google.dev
OPENAI_API_KEY=your_key               # platform.openai.com
GROQ_API_KEY=your_key                 # console.groq.com
OPENWEATHER_API_KEY=your_key          # free at openweathermap.org

# Service Ports
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
WEATHER_SERVICE_PORT=5003
CROP_SERVICE_PORT=5004
FERTILIZER_SERVICE_PORT=5005
MARKET_SERVICE_PORT=5006
LABOUR_SERVICE_PORT=5007
CHATBOT_SERVICE_PORT=5008

# Service URLs (for gateway)
AUTH_SERVICE_URL=http://localhost:5001
USER_SERVICE_URL=http://localhost:5002
WEATHER_SERVICE_URL=http://localhost:5003
CROP_SERVICE_URL=http://localhost:5004
FERTILIZER_SERVICE_URL=http://localhost:5005
MARKET_SERVICE_URL=http://localhost:5006
LABOUR_SERVICE_URL=http://localhost:5007
CHATBOT_SERVICE_URL=http://localhost:5008

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your_firebase_app_id
